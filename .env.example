# JARVIS AI — salin fail ini ke .env dan isi nilai

# auto = cuba Ollama dulu, kemudian OpenAI jika ada key
JARVIS_LLM_PROVIDER=auto
JARVIS_LLM_ENABLED=1

# OpenAI / ChatGPT (https://platform.openai.com/api-keys)
JARVIS_LLM_API_KEY=
JARVIS_LLM_MODEL=gpt-4o-mini
# JARVIS_LLM_BASE_URL=https://api.openai.com/v1

# Ollama percuma (local): https://ollama.com — jalankan `ollama pull llama3.2`
JARVIS_OLLAMA_URL=http://127.0.0.1:11434
JARVIS_OLLAMA_MODEL=llama3.2
